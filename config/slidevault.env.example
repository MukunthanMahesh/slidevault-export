# Local secrets for SlideVault export. Not committed to git.
# Create from this template:
#   cp config/slidevault.env.example slidevault.env
#   chmod 600 slidevault.env

export SLIDEVAULT_USER=""
export SLIDEVAULT_PASSWORD=""

# Absolute path for downloaded slides and annotation XML.
# Defaults to <repo>/exports when unset.
export SLIDEVAULT_OUT=""
